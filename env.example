# Copia questo file in ".env" e compila i valori.

# Token ottenuto da @BotFather su Telegram dopo aver creato il bot
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVwXYz

# ID Telegram numerico/i dell'amministratore (separati da virgola se più di uno).
# Per scoprire il proprio ID: scrivi a @userinfobot su Telegram.
ADMIN_IDS=123456789

# (opzionale) percorso del file database SQLite
DB_PATH=jamaicaplanner.db
